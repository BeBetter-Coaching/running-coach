# Voorbeeld-secrets. Kopieer dit naar `.streamlit/secrets.toml` en vul je eigen
# waarden in. `secrets.toml` staat in .gitignore en wordt NOOIT gecommit.
#
# LOKAAL:   vul garmin_email + garmin_password in. De eerste keer dat de app of
#           `scripts/garmin_login.py` draait, worden sessie-tokens opgeslagen in
#           data/garmin_tokens/ zodat je niet telkens opnieuw inlogt.
#
# STREAMLIT CLOUD: de schijf is daar vluchtig, dus zet bij voorkeur de
#           token-string `garmin_token_b64` (uit scripts/garmin_login.py).
#           Dan hoeft de app NOOIT met je wachtwoord in te loggen in de cloud.

garmin_email = "jouw-garmin-email@voorbeeld.nl"
garmin_password = "jouw-garmin-wachtwoord"

# Optioneel maar AANBEVOLEN voor Streamlit Cloud:
# de base64-tokenstring die `python scripts/garmin_login.py` voor je print.
# garmin_token_b64 = "plak-hier-de-lange-base64-string"

# AI-coach (Fase 2/3): Anthropic API-key (eigen workspace voor budgetscheiding).
# anthropic_api_key = "sk-ant-..."

# Koppeling met BeBetter (Fase 4 — alleen nodig om te publiceren):
#   fs_user_key = je FinalSurge user_key; wordt de athlete-key in garmin_state.json.
#   GH_TOKEN    = GitHub-token met SCHRIJFrechten op de repo bebetter-data.
# Zonder deze twee gebeurt er niets extern (je kunt wel een lokaal voorbeeld zien).
# fs_user_key = "jouw-finalsurge-user-key"
# GH_TOKEN = "ghp_..."
